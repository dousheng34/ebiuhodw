# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# SheerID credentials (from https://my.sheerid.com)
SHEERID_ACCESS_TOKEN=your_sheerid_access_token_here

# SheerID Program IDs (create programs in MySheerID portal)
SHEERID_PROGRAM_ID_STUDENT=your_student_program_id
SHEERID_PROGRAM_ID_MILITARY=your_military_program_id
SHEERID_PROGRAM_ID_TEACHER=your_teacher_program_id
SHEERID_PROGRAM_ID_FIRST_RESPONDER=your_first_responder_program_id

# GitHub storage (Personal Access Token with repo scope)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your_username/your_data_repo_name

# Server port
PORT=8080
